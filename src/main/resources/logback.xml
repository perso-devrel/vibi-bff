<configuration>
    <!--
      Cloud Run 자동 감지: K_SERVICE 환경변수는 GCP Cloud Run 이 모든 인스턴스에 자동 주입.
      이 변수 유무로 "GCP 환경 vs 로컬 dev" 분기. property 평가 실패 시 빈 문자열 → !=true.
    -->
    <if condition='isDefined("K_SERVICE")'>
        <then>
            <!--
              Cloud Run 출력. JSON 한 줄 포맷 → Cloud Logging 이 자동 파싱.
              severity 필드가 ERROR 면 GCP Error Reporting 이 자동 수집/그루핑 — 별도 SDK 불필요.
              stack_trace 도 동일 ReportedErrorEvent 스키마에 맞춰 emit.
            -->
            <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
                <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                    <!-- timestamp 필드명 = "time" (Cloud Logging 이 timestamp 로 자동 매핑) -->
                    <fieldNames>
                        <timestamp>time</timestamp>
                        <message>message</message>
                        <thread>thread</thread>
                        <logger>logger</logger>
                        <levelValue>[ignore]</levelValue>
                        <version>[ignore]</version>
                    </fieldNames>
                    <!-- Logback level → GCP severity 매핑. Cloud Logging 이 "severity" 키를 본다 —
                         단, GCP enum 은 WARNING (Logback 은 WARN) 이라 replace 필수.
                         TRACE → DEBUG, WARN → WARNING. INFO/ERROR 는 동일 문자열. -->
                    <provider class="net.logstash.logback.composite.loggingevent.LoggingEventPatternJsonProvider">
                        <pattern>
                            {
                                "severity": "%replace(%replace(%level){'WARN', 'WARNING'}){'TRACE', 'DEBUG'}"
                            }
                        </pattern>
                    </provider>
                    <!-- ERROR 수집 — stack_trace 필드가 있어야 Error Reporting 이 그루핑. -->
                    <includeMdc>true</includeMdc>
                    <includeContext>false</includeContext>
                </encoder>
            </appender>
        </then>
        <else>
            <!-- 로컬 dev: 사람 친화 한 줄 포맷 (기존과 동일). -->
            <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
                <encoder>
                    <pattern>%d{HH:mm:ss} %-5level %logger{24} - %msg%n</pattern>
                </encoder>
            </appender>
        </else>
    </if>

    <!--
      앱 코드는 INFO — DbBootstrap / BootCheck / AuthService 등의 의도된 info/warn 만 출력.
      디버깅 시 한시적으로 DEBUG 로 올려 사용.
    -->
    <logger name="com.vibi" level="INFO"/>

    <!--
      부팅 chatter 다운. 문제 발생 시 (pool 고갈 / 마이그레이션 실패 등) 만 WARN 으로 노출.
      DbBootstrap 자체가 Flyway 결과를 1줄 요약 (migrationsExecuted=N) 하므로 손실 없음.
    -->
    <logger name="com.zaxxer.hikari" level="WARN"/>
    <logger name="org.flywaydb" level="WARN"/>
    <logger name="io.ktor" level="INFO"/>
    <logger name="io.netty" level="WARN"/>

    <root level="WARN">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
