# vibi-bff — Oracle VM 런타임 env. 이 파일을 bff.env 로 복사 후 모두 채우기.
#   cp bff.env.example bff.env && vim bff.env
# bff.env 는 절대 commit 금지 (.gitignore 에 deploy/oracle/bff.env 추가됨).
#
# 값 출처: 기존 Cloud Run 운영값 그대로 옮기면 됨.
#   - Secret Manager 에 있던 값 → gcloud secrets versions access latest --secret=<NAME>
#   - GitHub Variables (R2_BUCKET 등) → repo Settings → Secrets and variables → Actions

# --- 공개 URL (필수) — 모바일이 호출하는 https 도메인. Caddyfile 의 도메인과 동일.
#     서명 stem URL 이 이 값으로 self-reference 하므로 반드시 https 도메인.
BFF_BASE_URL=https://api.example.com

# --- Perso AI (필수)
PERSO_API_KEY=
PERSO_SPACE_SEQ=

# --- Auth (필수)
GOOGLE_OAUTH_CLIENT_IDS=
APPLE_OAUTH_CLIENT_IDS=
AUTH_JWT_SECRET=
SEPARATION_SIGNING_SECRET=

# --- Postgres (Neon — 그대로 재사용, 컴퓨트만 바뀜)
DATABASE_URL=
DB_USER=
DB_PASSWORD=

# --- Cloudflare R2 (필수 — VM 디스크 영속 안 하므로 산출물은 R2 로. egress 무료)
R2_BUCKET=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# --- Caddy ACME (옵션) — Let's Encrypt 만료 알림 받을 이메일. 비워도 발급은 정상.
ACME_EMAIL=

# --- 옵션
# CORS_ALLOWED_ORIGINS=
# ADMIN_SLUG=
# SENTRY_DSN=
# IAP_APPLE_ISSUER_ID=
# IAP_APPLE_KEY_ID=
# IAP_APPLE_PRIVATE_KEY=
# IAP_APPLE_BUNDLE_ID=
