# Caddy 2 — 자동 HTTPS(Let's Encrypt) + bff:8080 리버스 프록시.
# 도메인 A 레코드가 이 VM 의 public IP 를 가리키면 Caddy 가 부팅 시 인증서를 알아서 발급/갱신.

{
	# ACME 만료 알림 이메일 — gitignored bff.env 의 ACME_EMAIL 로 주입 (커밋에 개인정보 안 남김).
	# 미설정이어도 Let's Encrypt 발급은 정상 동작 (만료 알림만 못 받음).
	email {$ACME_EMAIL}
}

# 도메인은 공개 정보라 커밋. 모바일 BFF_BASE_URL(https://api.vibi.fm) 과 동일.
api.vibi.fm {
	reverse_proxy bff:8080

	# /separate 업로드 ≤100MB. Caddy 는 기본 스트리밍(버퍼 0)이라 별도 한도 설정 불필요.
	# 혹시 모를 폭주 방어용 상한만 넉넉히.
	request_body {
		max_size 150MB
	}

	encode gzip
}
