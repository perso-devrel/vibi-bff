# vibi-bff — required env vars. copy to .env 후 모두 채우기.
# 옵션 변수는 application.conf default 사용 — 필요 시 .env 에 직접 추가.
#
# 이 파일의 용도: 로컬 dev (`./gradlew run`) + deploy/cloud-run.sh 부트스트랩 1회.
# 운영 (Cloud Run) env 의 단일 소스는 .github/workflows/deploy.yml 의 declarative wiring:
#   - GitHub Secrets:   GOOGLE_OAUTH_CLIENT_IDS, APPLE_OAUTH_CLIENT_IDS,
#                       GCP_WIF_PROVIDER, GCP_SA_EMAIL, GCP_PROJECT_ID, GCP_RUNTIME_SA_EMAIL
#   - GitHub Variables: CORS_ALLOWED_ORIGINS, BFF_BASE_URL (커스텀 도메인 — 미설정 시 자동 self-ref)
#   - Secret Manager:   PERSO_API_KEY, PERSO_SPACE_SEQ, AUTH_JWT_SECRET,
#                       SEPARATION_SIGNING_SECRET, DATABASE_URL, DB_USER, DB_PASSWORD
# 즉 운영 갱신은 GitHub repo Settings → Secrets and variables → Actions 에서. 그 후 push 또는 Run workflow.

# 콤마 분리 Google OAuth client IDs (iOS / Android / Web)
GOOGLE_OAUTH_CLIENT_IDS=

# 콤마 분리 Apple Sign In client IDs (보통 iOS bundle id `com.vibi.ios`).
# 비워두면 Apple 로그인 비활성 — /auth/apple 호출 시 503 apple_signin_disabled.
APPLE_OAUTH_CLIENT_IDS=

# HMAC-SHA256 키, 각각 32+ chars. openssl rand -hex 32
AUTH_JWT_SECRET=
SEPARATION_SIGNING_SECRET=

# Perso AI
PERSO_API_KEY=
PERSO_SPACE_SEQ=

# Vertex AI (Gemini) — Vertex AI 가 활성화된 GCP project ID.
# Cloud Run 이 배포된 프로젝트와 다를 수 있어 GCP_PROJECT_ID 와 이름 분리.
GEMINI_PROJECT_ID=
# 로컬 dev 전용 SA JSON 경로. 비우면 ADC 사용 (Cloud Run 의 attached SA,
# 또는 로컬 `gcloud auth application-default login` 캐시).
GOOGLE_APPLICATION_CREDENTIALS=

# Postgres (Neon managed) — user 영속화 + 향후 IAP entitlement.
# Neon UI 의 connection string 에 jdbc: 접두사 추가, user/password 는 분리해서 입력.
# 예: jdbc:postgresql://ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
# HikariCP pool 크기는 application.conf default 5 사용 — 튜닝 필요할 때만 DB_MAX_POOL 추가.
DATABASE_URL=
DB_USER=
DB_PASSWORD=
