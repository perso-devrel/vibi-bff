# vibi-bff — environment variables (copy to .env, fill REQUIRED)

# ---- Server ----
PORT=8080
STORAGE_PATH=./storage
BFF_BASE_URL=http://localhost:8080
# 콤마 분리 브라우저 origin 화이트리스트. 비우면 모든 host 허용 (DEV ONLY).
# 예: localhost:3000,localhost:8080 또는 app.example.com,admin.example.com
CORS_ALLOWED_ORIGINS=

# ---- Auth (Google OAuth + 자체 JWT) ----
# REQUIRED — 콤마 분리 Google OAuth client IDs (iOS / Android / Web)
GOOGLE_OAUTH_CLIENT_IDS=
# REQUIRED — HMAC-SHA256 키, 32+ chars. openssl rand -hex 32
AUTH_JWT_SECRET=
AUTH_JWT_EXPIRY_SECONDS=604800

# ---- Perso AI ----
# REQUIRED
PERSO_API_KEY=
PERSO_SPACE_SEQ=
PERSO_BASE_URL=https://api.perso.ai
# /perso-storage/... 다운로드용 Azure Blob CDN host (인증 X)
PERSO_STORAGE_BASE_URL=https://portal-media.perso.ai
PERSO_POLL_INTERVAL_MS=5000
PERSO_MAX_POLL_MINUTES=30
# SSRF 화이트리스트 (콤마 분리). baseUrl / storageBaseUrl host 는 자동 포함.
PERSO_DOWNLOAD_ALLOWED_HOSTS=portal-media.perso.ai

# ---- Vertex AI (Gemini) ----
# REQUIRED — Vertex AI 가 활성화된 GCP project
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash
# 로컬 dev 전용 — SA JSON 경로. 비우면 ADC 사용 (Cloud Run/GCE 의 attached SA,
# 또는 `gcloud auth application-default login` 캐시).
GOOGLE_APPLICATION_CREDENTIALS=

# ---- Separation / Render signed URLs ----
# REQUIRED — HMAC-SHA256 키, 32+ chars. openssl rand -hex 32
SEPARATION_SIGNING_SECRET=
SEPARATION_ABANDON_TTL_MS=1800000
SEPARATION_MIX_TTL_MS=600000
SEPARATION_URL_TTL_SEC=1800
SEPARATION_MIX_URL_TTL_SEC=600
