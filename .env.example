ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
PORT=8080
STORAGE_PATH=./storage
BFF_BASE_URL=http://localhost:8080

# Comma-separated browser origins allowed to call the BFF.
# Leave empty to allow any host (DEV ONLY — do not ship unset).
# Examples: localhost:3000,localhost:8080 or app.dubcast.com,admin.dubcast.com
CORS_ALLOWED_ORIGINS=

PERSO_BASE_URL=https://api.perso.ai
PERSO_API_KEY=
PERSO_SPACE_SEQ=
PERSO_POLL_INTERVAL_MS=5000
PERSO_MAX_POLL_MINUTES=30

SEPARATION_ABANDON_TTL_MS=1800000
SEPARATION_MIX_TTL_MS=600000
# Generate with: openssl rand -hex 32  (must be >= 32 chars)
SEPARATION_SIGNING_SECRET=CHANGE_ME_openssl_rand_hex_32
SEPARATION_URL_TTL_SEC=1800
SEPARATION_MIX_URL_TTL_SEC=600
